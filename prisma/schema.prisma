generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientType {
  person
  company
}

enum DealStatus {
  draft
  sent
  paid
  completed
  cancelled
}

enum PaymentStatus {
  unpaid
  partial
  paid
}

enum DocumentType {
  contract
  act
  invoice
}

enum ReminderType {
  payment_followup
  issue_receipt
  close_act
}

model User {
  id               String           @id @default(cuid())
  login            String           @unique
  passwordHash     String
  email            String?          @unique
  name             String?
  avatarUrl        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  lastLoginAt      DateTime?
  profile          Profile?
  businessDetails  BusinessDetails?
  clients          Client[]
  serviceTemplates ServiceTemplate[]
  deals            Deal[]
  documents        Document[]
  reminders        Reminder[]
}

model Profile {
  id         String   @id @default(cuid())
  userId     String   @unique
  role       String   @default("self_employed")
  profession String?
  fullName   String?
  phone      String?
  inn        String?
  city       String?
  telegram   String?
  website    String?
  about      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BusinessDetails {
  id              String   @id @default(cuid())
  userId          String   @unique
  legalStatus     String   @default("self_employed")
  displayName     String?
  signerName      String?
  emailForDocs    String?
  paymentPhone    String?
  paymentBank     String?
  paymentCardMask String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Client {
  id          String     @id @default(cuid())
  userId      String
  type        ClientType
  name        String
  contactName String?
  phone       String?
  email       String?
  companyName String?
  inn         String?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deals       Deal[]

  @@index([userId, name])
}

model ServiceTemplate {
  id                String   @id @default(cuid())
  userId            String
  title             String
  description       String?
  price             Decimal  @db.Decimal(12, 2)
  prepaymentPercent Int?
  deadlineDays      Int?
  unit              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deals             Deal[]

  @@index([userId, title])
}

model Deal {
  id                String           @id @default(cuid())
  userId            String
  clientId          String
  serviceTemplateId String?
  title             String
  description       String?
  amount            Decimal          @db.Decimal(12, 2)
  prepaymentAmount  Decimal?         @db.Decimal(12, 2)
  status            DealStatus       @default(draft)
  paymentStatus     PaymentStatus    @default(unpaid)
  startDate         DateTime?
  dueDate           DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  client            Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceTemplate   ServiceTemplate? @relation(fields: [serviceTemplateId], references: [id], onDelete: SetNull)
  documents         Document[]
  reminders         Reminder[]

  @@index([userId, status])
  @@index([clientId])
  @@index([serviceTemplateId])
}

model Document {
  id          String       @id @default(cuid())
  userId      String
  dealId      String
  type        DocumentType
  fileUrl     String?
  docNumber   String?
  generatedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal        Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([userId, dealId, type])
}

model Reminder {
  id           String       @id @default(cuid())
  userId       String
  dealId       String
  type         ReminderType
  scheduledFor DateTime
  done         Boolean      @default(false)
  createdAt    DateTime     @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal         Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([userId, scheduledFor])
  @@index([dealId])
}
